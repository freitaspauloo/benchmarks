{
  "mcpServers": {
    "mintlify-docs": {
      "url": "https://mintlify.com/docs/mcp"
    },
    "mintlify": {
      "command": "node",
      "args": [
        "scripts/mintlify-admin-mcp-bridge.mjs"
      ],
      "env": {
        "MINTLIFY_MCP_CLIENT_ID": "${env:MINTLIFY_MCP_CLIENT_ID}",
        "MINTLIFY_MCP_CLIENT_SECRET": "${env:MINTLIFY_MCP_CLIENT_SECRET}"
      }
    },
    "aligned-benchmarks": {
      "url": "https://dudesign.mintlify.io/mcp"
    }
  }
}
