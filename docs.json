{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Aligned AI Research",
  "description": "Benchmarks, model context, and roadmap for Aligned AI.",
  "appearance": {
    "default": "light",
    "strict": true
  },
  "colors": {
    "primary": "#18181b",
    "light": "#f4f4f5",
    "dark": "#09090b"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "navbar": {
    "links": [
      {
        "label": "Aligned AI",
        "href": "https://joinaligned.ai"
      },
      {
        "label": "Enterprise",
        "href": "https://joinaligned.ai/enterprise"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Start for free",
      "href": "https://joinaligned.ai/choose-plan"
    }
  },
  "footer": {
    "socials": {
      "website": "https://joinaligned.ai"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Research",
        "public": true,
        "pages": [
          "index",
          {
            "group": "General benchmark",
            "expanded": true,
            "pages": [
              "general",
              "general/all-models",
              "general/pricing-inputs",
              "general/methodology"
            ]
          },
          {
            "group": "CEFeAI benchmark",
            "expanded": true,
            "pages": [
              "cefeai",
              "cefeai/religious-representation",
              "cefeai/conversion-bias",
              "cefeai/bias-by-faith"
            ]
          },
          {
            "group": "Model",
            "expanded": true,
            "pages": ["model", "model/what-we-measure"]
          },
          {
            "group": "Roadmap",
            "expanded": true,
            "pages": ["roadmap", "roadmap/published", "roadmap/next"]
          }
        ]
      }
    ]
  },
  "redirects": [
    { "source": "/general", "destination": "/#general-benchmark" },
    { "source": "/general/all-models", "destination": "/#all-models-by-accuracy" },
    { "source": "/general/pricing-inputs", "destination": "/#pricing-inputs-public-api-rates" },
    { "source": "/general/methodology", "destination": "/#methodology" },
    { "source": "/cefeai", "destination": "/#cefeai-benchmark" },
    { "source": "/cefeai/religious-representation", "destination": "/#religious-representation" },
    { "source": "/cefeai/conversion-bias", "destination": "/#conversion-bias" },
    { "source": "/cefeai/bias-by-faith", "destination": "/#bias-by-model-and-faith" },
    { "source": "/model", "destination": "/#model" },
    { "source": "/model/what-we-measure", "destination": "/#what-the-benchmarks-measure" },
    { "source": "/roadmap", "destination": "/#roadmap" },
    { "source": "/roadmap/published", "destination": "/#published" },
    { "source": "/roadmap/next", "destination": "/#next" }
  ]
}
