{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Aligned AI Research",
  "description": "Benchmarks, model context, and roadmap for Aligned AI.",
  "appearance": {
    "default": "light",
    "strict": true
  },
  "colors": {
    "primary": "#22a06b",
    "light": "#ebf6f2",
    "dark": "#027864"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "navbar": {
    "links": [
      {
        "label": "Aligned AI",
        "href": "https://joinaligned.ai"
      },
      {
        "label": "Enterprise",
        "href": "https://joinaligned.ai/enterprise"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Start for free",
      "href": "https://joinaligned.ai/choose-plan"
    }
  },
  "footer": {
    "socials": {
      "website": "https://joinaligned.ai"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Research",
        "public": true,
        "pages": ["index"]
      }
    ]
  },
  "redirects": [
    { "source": "/general", "destination": "/#general" },
    { "source": "/general/:slug*", "destination": "/#general" },
    { "source": "/cefeai", "destination": "/#cefeai" },
    { "source": "/cefeai/:slug*", "destination": "/#cefeai" },
    { "source": "/model", "destination": "/#model" },
    { "source": "/model/:slug*", "destination": "/#model" },
    { "source": "/roadmap", "destination": "/#roadmap" },
    { "source": "/roadmap/:slug*", "destination": "/#roadmap" }
  ]
}
